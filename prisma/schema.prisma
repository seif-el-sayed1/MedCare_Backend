// config
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  DOCTOR
}

enum Lang {
  EN
  AR
}

enum LoginType {
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
}

enum Gender {
  MALE
  FEMALE
}

enum Specialization {
  INTERNAL_MEDICINE
  PEDIATRICS
  CARDIOLOGY
  DERMATOLOGY
  ORTHOPEDICS
  NEUROLOGY
  OPHTHALMOLOGY
  ENT
  DENTISTRY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  ABSENT
}

enum WaitingListStatus {
  WAITING
  ACCEPTED
  REJECTED
}

enum LabTestType {
  CBC
  BLOOD_SUGAR
  LIVER_FUNCTION
  KIDNEY_FUNCTION
  URINE_ANALYSIS
  THYROID_FUNCTION
}

enum LabTestStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum PaymentTypes {
  PARTIALLY_PAID
  FULLY_PAID
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// Models
model Admin {
  id                     String    @id @default(uuid())
  firstName              String
  lastName               String
  email                  String    @unique
  role                   Role      @default(ADMIN)
  password               String
  phone                  String?   @unique
  isSuperAdmin           Boolean   @default(false)
  isVerified             Boolean   @default(false)
  isBlocked              Boolean   @default(false)
  isDeleted              Boolean   @default(false)
  passwordChangedAt      DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  verificationToken      String?
  verificationTokenExp   DateTime?
  token                  String?
  tokenExpDate           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([firstName, lastName])
}

model User {
  id                        String         @id @default(uuid())
  lang                      Lang           @default(EN)
  loginType                 LoginType      @default(EMAIL)
  firstName                 String
  lastName                  String
  profilePicture            String?        @default("")
  role                      Role           @default(USER)
  gender                    Gender
  email                     String         @unique
  phone                     String?        @unique
  age                       Int?
  // Password
  password                  String
  passwordChangedAt         DateTime?
  passwordResetCode         String?
  passwordResetCodeExp      DateTime?
  passwordResetCodeVerified Boolean?
  // Verification
  verificationCode          String?
  verificationCodeExp       DateTime?
  verificationCodeVerified  Boolean?
  passwordVerificationToken String?
  passwordResetExpiresAt    DateTime?
  isVerified                Boolean        @default(false)
  // Active
  deactivatedAt             DateTime?
  isActive                  Boolean        @default(true)
  isBlocked                 Boolean        @default(false)
  // Auth
  token                     String?
  tokenExpDate              DateTime?
  notificationToken         String?        @default("")
  // Timestamps
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  appointments              Appointment[]
  payments                  Payment[]
  waitingLists              WaitingList[]
  notifications             Notification[]
  ratings                   Rating[]

  @@index([firstName, lastName])
}

model WorkingHours {
  id           String  @id @default(uuid())
  doctorId     String
  doctor       Doctor  @relation(fields: [doctorId], references: [id])
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int     @default(30)
  isAvailable  Boolean @default(true)
  weeksOfLeave Int     @default(0)

  @@unique([doctorId, dayOfWeek])
}

model Doctor {
  id                     String         @id @default(uuid())
  firstName              String
  lastName               String
  profilePicture         String?        @default("")
  email                  String         @unique
  role                   Role           @default(DOCTOR)
  password               String
  specialization         Specialization
  phone                  String         @unique
  consultationPrice      Float          @default(0)
  bio                    String?
  experienceYears        Int            @default(0)
  ratingsAverage         Float          @default(0)
  ratingQuantity         Int            @default(0)
  isVerified             Boolean        @default(false)
  isDeleted              Boolean        @default(false)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  workingHours           WorkingHours[]
  // auth
  passwordChangedAt      DateTime?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  verificationToken      String?
  verificationTokenExp   DateTime?
  token                  String?
  tokenExpDate           DateTime?
  // leaves            DoctorLeave[]
  appointments           Appointment[]
  waitingLists           WaitingList[]
  ratings                Rating[]

  @@index([firstName, lastName])
}

model Payment {
  id            String        @id @default(uuid())
  appointmentId String
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  orderCode     String        @unique
  amount        Float
  billedAmount  Float
  cardNum       String?
  cardType      String?
  currency      String?
  success       Boolean?
  pending       Boolean       @default(true)
  status        PaymentStatus @default(PENDING)
  clientSecret  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model WaitingList {
  id            String            @id @default(uuid())
  userId        String
  doctorId      String
  requestedDate DateTime
  paymentType   PaymentTypes
  status        WaitingListStatus @default(WAITING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([userId, doctorId, requestedDate])
}

model Appointment {
  id                String            @id @default(uuid())
  doctorId          String
  userId            String
  appointmentDate   DateTime
  appointmentStatus AppointmentStatus @default(PENDING)
  totalPrice        Float             @default(0)
  paidAmount        Float             @default(0)
  remainingAmount   Float             @default(0)
  paymentType       PaymentTypes
  isPaid            Boolean           @default(false)
  isFullPaid        Boolean           @default(false)
  appointmentCode   String?           @unique
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  doctor   Doctor    @relation(fields: [doctorId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@index([doctorId, appointmentDate])
  @@index([userId, appointmentStatus])
  @@index([appointmentDate])
}

model Notification {
  id           String    @id @default(uuid())
  title        String
  body         String?
  case         String?
  info         String?
  global       Boolean   @default(false)
  seen         Boolean   @default(false)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
  scheduleTime DateTime? @default(now())

  @@index([userId, seen])
}

model Rating {
  id        String   @id @default(uuid())
  doctorId  String
  userId    String
  review    String?
  rating    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([doctorId, userId])
  @@index([doctorId])
}
